<Page
    x:Class="YtDlpGUI.Views.QueuePage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Padding="20,8,20,20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <Button Click="OnAddDownloadClick" Content="Add Download..." />
            <Button Command="{Binding StartQueueCommand}" Content="Start Queue" Style="{StaticResource PrimaryActionButtonStyle}" />
            <Button Command="{Binding PauseQueueCommand}" Content="Pause Queue" />
            <Button Command="{Binding ClearCompletedCommand}" Content="Clear Completed" />
            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center">
                <Run Text="Queue Active: " />
                <Run Text="{Binding IsQueueRunning}" />
            </TextBlock>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <ListView
                    ItemsSource="{Binding Jobs}"
                    SelectedItem="{Binding SelectedJob, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                <Grid RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="12" Opacity="0.7" Text="{Binding Url}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="{Binding Status, Converter={StaticResource QueueStatusToBrushConverter}}" CornerRadius="999" Padding="10,2">
                                            <TextBlock Foreground="White" Text="{Binding Status}" />
                                        </Border>
                                    </Grid>

                                    <ProgressBar Grid.Row="1" Maximum="100" Value="{Binding ProgressPercent}" />

                                    <Grid Grid.Row="2" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding LastError}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="1" Content="Up" Command="{Binding DataContext.MoveUpJobCommand, ElementName=RootPage}" CommandParameter="{Binding JobId}" />
                                        <Button Grid.Column="2" Content="Down" Command="{Binding DataContext.MoveDownJobCommand, ElementName=RootPage}" CommandParameter="{Binding JobId}" />
                                        <Button Grid.Column="3" Content="Cancel" Command="{Binding DataContext.CancelJobCommand, ElementName=RootPage}" CommandParameter="{Binding JobId}" />
                                        <Button Grid.Column="4" Content="Retry" Command="{Binding DataContext.RetryJobCommand, ElementName=RootPage}" CommandParameter="{Binding JobId}" />
                                        <Button Grid.Column="5" Content="Remove" Command="{Binding DataContext.RemoveJobCommand, ElementName=RootPage}" CommandParameter="{Binding JobId}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="8">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Selected Job Logs" />
                <ListView ItemsSource="{Binding SelectedJob.Logs}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock TextWrapping="Wrap">
                                <Run Text="{Binding Severity}" />
                                <Run Text=": " />
                                <Run Text="{Binding Message}" />
                            </TextBlock>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </Grid>
</Page>

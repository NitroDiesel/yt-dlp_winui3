<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="YtDlpGUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:YtDlpGUI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="BrandColor">#0B6AB3</Color>
            <SolidColorBrush x:Key="BrandBrush" Color="{StaticResource BrandColor}" />

            <SolidColorBrush x:Key="CardBorderBrush" Color="#22000000" />

            <converters:QueueStatusToBrushConverter x:Key="QueueStatusToBrushConverter" />
            <converters:EnumDisplayNameConverter x:Key="EnumDisplayNameConverter" />

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>

            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            </Style>

            <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                <Setter Property="MinWidth" Value="140" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style x:Key="DialogSecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="MinWidth" Value="140" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
